# --- REQUIRED ---

# Target to monitor:
#   Docker mode → container name (e.g. my-app)
#   Kubernetes mode → deployment name (e.g. my-deployment)
BACKTRACK_TARGET=my-app

# Image tag for rollback snapshot reference
BACKTRACK_IMAGE_TAG=latest


# --- OPTIONAL ---

# GitHub personal access token — only needed for the "Recent Deployments" panel
# Leave blank if you don't want to wire up GitHub
GITHUB_TOKEN=

# Mode: docker | kubernetes (auto-detected if blank)
BACKTRACK_MODE=

# Kubernetes namespace (only used in kubernetes mode)
BACKTRACK_K8S_NAMESPACE=default

# Disable auto-rollback (set to false to make rollbacks manual-only)
BACKTRACK_ROLLBACK_ENABLED=true

# How often the agent scrapes metrics, in seconds
BACKTRACK_SCRAPE_INTERVAL=10

