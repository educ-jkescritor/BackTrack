# =============================================================
#  BackTrack — environment configuration
#  Copy this file to .env and fill in your values.
# =============================================================


# -------------------------------------------------------------
# REQUIRED
# -------------------------------------------------------------

# Target service to monitor.
#   Docker mode  → Docker container name (e.g. my-app)
#   Kubernetes   → Deployment / pod name prefix (e.g. frontend)
BACKTRACK_TARGET=my-app
# --- OPTIONAL (can also be set via dashboard "Configure Cluster" button) ---

# Target to monitor:
#   Docker mode → container name (e.g. my-app)
#   Kubernetes mode → deployment name (e.g. my-deployment)
#   Leave empty to configure via dashboard's "Configure Cluster" modal
BACKTRACK_TARGET=

# Image tag used as the rollback snapshot reference.
BACKTRACK_IMAGE_TAG=latest


# -------------------------------------------------------------
# KUBERNETES — kubeconfig (docker-compose only)
#
# Both containers mount your .kube directory so kubectl can
# reach the cluster. Two variables control this:
#
#   KUBE_DIR        — host path to your .kube folder
#   KUBECONFIG_FILE — which config file inside that folder to use
#
# ┌─ Linux / Mac ─────────────────────────────────────────────┐
# │ Default KUBE_DIR=~/.kube works out of the box.            │
# │                                                           │
# │ minikube with Docker driver uses 127.0.0.1 in the         │
# │ kubeconfig, which is unreachable from inside a container. │
# │ Create a Docker-safe copy once:                           │
# │                                                           │
# │   sed 's|https://127.0.0.1|https://host.docker.internal|g'│
# │       ~/.kube/config > ~/.kube/config-docker              │
# │                                                           │
# │ Then set: KUBECONFIG_FILE=config-docker                   │
# │                                                           │
# │ VM-based drivers (kvm2, virtualbox, hyperkit) expose the  │
# │ API server on a stable VM IP — no patching needed,        │
# │ leave KUBECONFIG_FILE=config.                             │
# └───────────────────────────────────────────────────────────┘
#
# ┌─ Windows (Docker Desktop) ────────────────────────────────┐
# │ Set the full path to your .kube folder:                   │
# │   KUBE_DIR=C:/Users/<you>/.kube                           │
# │                                                           │
# │ minikube Docker driver — patch the config in PowerShell:  │
# │   (Get-Content ~/.kube/config) `                          │
# │     -replace 'https://127.0.0.1', `                       │
# │              'https://host.docker.internal' |             │
# │     Set-Content ~/.kube/config-docker                     │
# │                                                           │
# │ Then set: KUBECONFIG_FILE=config-docker                   │
# └───────────────────────────────────────────────────────────┘
#
# Docker-only users: leave both values as-is. An empty .kube
# directory is mounted harmlessly and kubectl is never called.
# -------------------------------------------------------------

KUBE_DIR=~/.kube
KUBECONFIG_FILE=config


# -------------------------------------------------------------
# OPTIONAL
# -------------------------------------------------------------

# GitHub personal access token — only needed for "Recent Deployments"
GITHUB_TOKEN=

# Mode: docker | kubernetes  (auto-detected if blank)
BACKTRACK_MODE=

# Kubernetes namespace
BACKTRACK_K8S_NAMESPACE=default

# Kubernetes label selector override (default: app=<BACKTRACK_TARGET>)
BACKTRACK_K8S_LABEL_SELECTOR=

# Disable auto-rollback (false = manual rollbacks only)
BACKTRACK_ROLLBACK_ENABLED=true

# Minimum seconds between consecutive auto-rollbacks
BACKTRACK_ROLLBACK_COOLDOWN=120

# Scrape interval in seconds
BACKTRACK_SCRAPE_INTERVAL=10

# Seconds of clean metrics before a version is marked STABLE
BACKTRACK_STABLE_SECONDS=600

# TSD drift sensitivity — lower = more alerts
BACKTRACK_TSD_IQR_MULTIPLIER=3.0

# LSI anomaly sensitivity — lower = more alerts
BACKTRACK_LSI_SCORE_MULTIPLIER=2.0

# SVD cosine similarity cutoff — raise to reduce NOVEL false positives
BACKTRACK_SVD_SIMILARITY_THRESHOLD=0.55

# Log lines collected before fitting the LSI model
BACKTRACK_CORPUS_SIZE=200

# Scoring windows before locking the LSI baseline
BACKTRACK_BASELINE_WINDOWS=10

# LSI scoring window duration in seconds
BACKTRACK_WINDOW_SECONDS=30

# Directory for rollback log and version snapshots (inside agent container)
BACKTRACK_DATA_DIR=/data
